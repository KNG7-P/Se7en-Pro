<Window x:Class="PsiphonUI.Views.CloseConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PsiphonUI"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="{StaticResource UI.FontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="14"
            Padding="24,22,24,20"
            Margin="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="{DynamicResource Surface.SubtleBg}"
                        BorderBrush="{DynamicResource Surface.SubtleBorder}"
                        BorderThickness="1"
                        Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="ExitToApp" Width="22" Height="22"
                                              Foreground="{StaticResource Brand.PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Close PsiphonUI?"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                    <TextBlock Text="What would you like to do?"
                               FontSize="12" Opacity="0.70"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                </StackPanel>
            </StackPanel>

            <Border Background="{DynamicResource Surface.SubtleBg}"
                    BorderBrush="{DynamicResource Surface.SubtleBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12"
                    Margin="0,0,0,10"
                    Cursor="Hand"
                    MouseLeftButtonUp="OnMinimizeRowClicked">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0"
                                              Kind="ArrowDownDropCircleOutline"
                                              Width="22" Height="22"
                                              Foreground="{StaticResource Brand.PrimaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Minimize to system tray"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                        <TextBlock Text="Keep PsiphonUI running in the background."
                                   FontSize="11" Opacity="0.70"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="2"
                                              Kind="ChevronRight"
                                              Width="20" Height="20"
                                              Opacity="0.55"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource MaterialDesignBody}" />
                </Grid>
            </Border>

            <Border Background="{DynamicResource Surface.SubtleBg}"
                    BorderBrush="{DynamicResource Surface.SubtleBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12"
                    Margin="0,0,0,14"
                    Cursor="Hand"
                    MouseLeftButtonUp="OnExitRowClicked">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0"
                                              Kind="CloseCircleOutline"
                                              Width="22" Height="22"
                                              Foreground="{StaticResource Brand.ErrorBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Close completely"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                        <TextBlock Text="Disconnect the tunnel and exit PsiphonUI."
                                   FontSize="11" Opacity="0.70"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="2"
                                              Kind="ChevronRight"
                                              Width="20" Height="20"
                                              Opacity="0.55"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource MaterialDesignBody}" />
                </Grid>
            </Border>

            <CheckBox x:Name="RememberCheckBox"
                      Content="Remember my choice (don't ask again)"
                      Margin="0,0,0,12"
                      Foreground="{DynamicResource MaterialDesignBody}" />

            <Button x:Name="CancelButton"
                    Style="{StaticResource UI.GhostButton}"
                    Content="Cancel"
                    HorizontalAlignment="Right"
                    Padding="18,6"
                    Click="OnCancelClicked"
                    IsCancel="True" />
        </StackPanel>
    </Border>
</Window>
